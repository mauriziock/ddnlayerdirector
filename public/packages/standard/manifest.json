{
    "id": "hangar-standard",
    "name": "Hangar Standard Package",
    "description": "Plantilla base con Bridge integrado y diseño minimalista.",
    "version": "1.0.0",
    "requirements": {
        "layers": [
            {
                "id": "hud_main",
                "type": "web_source",
                "url": "./index.html",
                "z_index": 100,
                "position": {
                    "x": 0,
                    "y": 0,
                    "width": 100,
                    "height": 100
                }
            }
        ],
        "triggers": [
            {
                "id": "idle",
                "name": "Modo Reposo",
                "action": "class_toggle",
                "target": "body",
                "value": "state-idle"
            },
            {
                "id": "alert",
                "name": "Lanzar Alerta",
                "action": "trigger",
                "target": "body",
                "value": "alert"
            }
        ]
    }
}